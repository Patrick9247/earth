[project]
requires = ["python-3.11", "nodejs-20"]

[dev]
build = [
    "bash", "-c",
    """cd frontend && pnpm install && pnpm build && 
       cd ../backend && pip install -r requirements.txt"""
]
run = ["bash", "-c", "cd backend && python main.py"]

[deploy]
build = [
    "bash", "-c",
    """cd frontend && pnpm install && pnpm build && 
       cd ../backend && pip install -r requirements.txt"""
]
run = ["bash", "-c", "cd backend && python main.py"]
