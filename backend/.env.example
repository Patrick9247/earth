# ==================== 数据库配置 ====================
# 是否使用 SQLite（设为 false 使用 MySQL）
USE_SQLITE=false

# MySQL 连接配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=geothermal_db

# ==================== 环境配置 ====================
COZE_WORKSPACE_PATH=/workspace/projects
COZE_PROJECT_ENV=DEV
